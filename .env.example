# Choose one: gemini or openai-compatible
GRASP_LLM_PROVIDER=gemini
GRASP_LLM_MODEL=gemini-3-pro-preview

# Gemini
GEMINI_API_KEY=

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Short aliases accepted by the CLI for OpenAI-compatible providers
API_KEY=
API_BASE_URL=

# Optional runtime defaults
GRASP_LLM_TIMEOUT=180
GRASP_LLM_MAX_RETRIES=3
